                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Search"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,4" />
                        <TextBlock Grid.Column="2"
                                   Text="Target"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,4" />
                        <TextBlock Grid.Column="4"
                                   Text="Location"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,4" />
                        <TextBlock Grid.Column="6"
                                   Text="Session type"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,4" />
                        <TextBlock Grid.Column="8"
                                   Text="Sort"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,4" />
                        <TextBox Grid.Row="1"
                                 Text="{Binding HistorySearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search target, location, problems, and notes" />
                        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding HistoryTargetFilter}" ToolTip="Target filter" />
                        <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding HistoryLocationFilter}" ToolTip="Location filter" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="6"
                                  ItemsSource="{Binding HistoryTypeFilters}"
                                  SelectedItem="{Binding SelectedHistoryTypeFilter}" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="8"
                                  ItemsSource="{Binding HistorySortOptions}"
                                  SelectedItem="{Binding SelectedHistorySort}" />
                        <Button Grid.Row="1"
                                Grid.Column="10"
                                Content="Apply filters"
                                Command="{Binding RefreshHistoryCommand}"
                                Style="{StaticResource AccentButton}" />
                        <WrapPanel Grid.Row="2"
                                   Grid.ColumnSpan="11"
                                   Margin="0,9,0,0">
                            <TextBlock Text="From" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <DatePicker SelectedDate="{Binding HistoryFromDate}" Width="135" Margin="0,0,12,0" />
                            <TextBlock Text="To" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <DatePicker SelectedDate="{Binding HistoryToDate}" Width="135" Margin="0,0,12,0" />
                            <TextBlock Text="Minimum rating" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <ComboBox ItemsSource="{Binding HistoryRatingOptions}"
                                      SelectedItem="{Binding HistoryMinimumRating}"
                                      Width="65"
                                      Margin="0,0,12,0" />
                            <Button Content="Clear dates"
                                    Style="{StaticResource ToolbarButton}"
                                    Click="ClearHistoryDates_OnClick" />
                        </WrapPanel>
                    </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource PanelCard}" Padding="8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Bottom"
                                       Text="{Binding HistoryStatusText}"
                                       Style="{StaticResource MutedText}"
                                       Margin="8" />
                            <ListBox ItemsSource="{Binding History}"
                                     SelectedItem="{Binding SelectedHistorySession}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Target}" FontWeight="SemiBold" FontSize="15" />
                                                <TextBlock Text="{Binding Summary}" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                                                <TextBlock Text="{Binding DateText}" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding FramesText}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding RatingText}" Foreground="{DynamicResource WarningBrush}" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PanelCard}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                        <ScrollViewer Grid.Row="0"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      PanningMode="VerticalFirst"
                                      PanningDeceleration="0.001"
                                      PanningRatio="1">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedHistorySession}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>
                            <StackPanel Margin="18"
                                        DataContext="{Binding SelectedHistorySession}">
                                <DockPanel>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Target}" FontSize="24" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DateText}" Style="{StaticResource MutedText}" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding RatingText}" Foreground="{DynamicResource WarningBrush}" FontSize="17" />
                                        <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}" HorizontalAlignment="Right" />
                                    </StackPanel>
                                </DockPanel>
                                <Border Style="{StaticResource SeparatorLine}" />
                                <UniformGrid Columns="4">
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="TYPE" Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="{Binding Type}" Style="{StaticResource MetricValue}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="DURATION" Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="{Binding DurationText}" Style="{StaticResource MetricValue}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="FRAMES" Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="{Binding FramesText}" Style="{StaticResource MetricValue}" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="INTEGRATION" Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="{Binding IntegrationText}" Style="{StaticResource MetricValue}" />
                                    </StackPanel>
                                </UniformGrid>
                                <Border Style="{StaticResource SeparatorLine}" />
                                <TextBlock Text="CONDITIONS" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="{Binding ConditionsSummary}" />
                                <TextBlock Text="CAPTURE SETTINGS" Style="{StaticResource SectionTitle}" Margin="0,16,0,8" />
                                <TextBlock Text="{Binding SettingsSummary}" />
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="BATTERY" Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="{Binding BatterySummary}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="FREE STORAGE" Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="{Binding StorageSummary}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="TIMELINE &amp; NOTES" Style="{StaticResource SectionTitle}" Margin="0,18,0,8" />
                                <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="6" Padding="10">
                                    <TextBlock Text="{Binding NotesText}" />
                                </Border>
                                <TextBlock Text="PREVIEW SCREENSHOTS" Style="{StaticResource SectionTitle}" Margin="0,18,0,8" />
                                <ItemsControl ItemsSource="{Binding ScreenshotPaths}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="4" Padding="8" Margin="0,0,0,5">
                                                <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" ToolTip="{Binding}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <TextBlock Grid.Row="0"
                                   Text="Select a session to inspect its conditions, capture settings, notes, screenshots, and device usage."
                                   FontSize="14"
                                   MaxWidth="430"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedHistorySession}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Border Grid.Row="1"
                                Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedHistorySession}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBox Grid.Row="0"
                                         Text="{Binding HistoryEditProblems, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Edit problems / outcome notes"
                                         MinHeight="32" />
                                <DockPanel Grid.Row="2">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Start plan" Command="{Binding StartSelectedPlanCommand}" Style="{StaticResource AccentButton}" Margin="0,0,6,0" />
                                        <Button Content="Duplicate plan" Command="{Binding DuplicateSelectedSessionCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,6,0" />
                                        <Button Content="Export JSON" Command="{Binding ExportSelectedJsonCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,6,0" />
                                        <Button Content="Export Markdown" Command="{Binding ExportSelectedMarkdownCommand}" Style="{StaticResource ToolbarButton}" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <TextBlock Text="Rating" VerticalAlignment="Center" Margin="0,0,5,0" />
                                        <ComboBox Width="55"
                                                  ItemsSource="{Binding RatingOptions}"
                                                  SelectedItem="{Binding HistoryEditRating}"
                                                  Margin="0,0,6,0" />
                                        <Button Content="Save edits" Command="{Binding SaveHistoryEditsCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,6,0" />
                                        <Button Content="Delete" Command="{Binding DeleteSelectedSessionCommand}" Style="{StaticResource DangerButton}" />
                                    </StackPanel>
                                </DockPanel>
                            </Grid>
                        </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Grid Visibility="{Binding IsSettings, Converter={StaticResource BoolToVisibility}}"
                  Margin="24">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              PanningMode="VerticalFirst"
                              PanningDeceleration="0.001"
                              PanningRatio="1">
                    <StackPanel MaxWidth="1240" HorizontalAlignment="Center">
                        <TextBlock Text="Settings" Style="{StaticResource PageTitle}" />
                        <TextBlock Text="Tune the field workflow without cluttering the shooting screen."
                                   Style="{StaticResource PageSubtitle}" />
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <Border Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="ANDROID TOOLS" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="ADB executable" Style="{StaticResource FieldLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="6" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding AdbPath}" />
                                        <Button Grid.Column="2" Content="Browse…" Click="BrowseAdb_OnClick" Style="{StaticResource ToolbarButton}" />
                                    </Grid>
                                    <TextBlock Text="scrcpy executable" Style="{StaticResource FieldLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="6" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding ScrcpyPath}" />
                                        <Button Grid.Column="2" Content="Browse…" Click="BrowseScrcpy_OnClick" Style="{StaticResource ToolbarButton}" />
                                    </Grid>
                                    <UniformGrid Columns="3" Margin="0,8,0,0">
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Bitrate (Mbps)" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding ScrcpyBitrateMbps}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Max resolution" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding ScrcpyMaxResolution}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Max FPS" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding ScrcpyMaxFps}" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <CheckBox Content="Automatically launch scrcpy at startup"
                                              IsChecked="{Binding AutomaticallyLaunchScrcpy}"
                                              Margin="0,10,0,0" />
                                    <CheckBox Content="Automatically reconnect ADB"
                                              IsChecked="{Binding AutomaticallyReconnect}"
                                              Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="FILES &amp; LOCAL DATA" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="Preview screenshot folder" Style="{StaticResource FieldLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="6" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding ScreenshotFolder}" />
                                        <Button Grid.Column="2" Content="Browse…" Click="BrowseScreenshotFolder_OnClick" Style="{StaticResource ToolbarButton}" />
                                    </Grid>
                                    <TextBlock Text="Session data folder" Style="{StaticResource FieldLabel}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="6" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding SessionDataFolder}" />
                                        <Button Grid.Column="2" Content="Browse…" Click="BrowseSessionFolder_OnClick" Style="{StaticResource ToolbarButton}" />
                                    </Grid>
                                    <CheckBox Content="Include framing overlays in preview screenshots"
                                              IsChecked="{Binding IncludeOverlaysInScreenshot}"
                                              Margin="0,10,0,0" />
                                    <CheckBox Content="Use live weather and automatic Windows location"
                                              IsChecked="{Binding EnableNetworkConditions}"
                                              Margin="0,8,0,0" />
                                    <TextBlock Text="On by default. Windows location is tried first. If unavailable, BigDataCloud may estimate the area from the public IP address. Coordinates are sent to Open-Meteo for weather, elevation, and time-zone data. A broad public sky-brightness tile is requested for light-pollution estimates. Screenshots, phone status, sessions, and logs are never uploaded."
                                               Style="{StaticResource MutedText}"
                                               Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelCard}">
                                <StackPanel>
                                    <TextBlock Text="REFRESH &amp; DEFAULTS" Style="{StaticResource SectionTitle}" />
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Phone status (seconds)" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding StatusRefreshSeconds}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Weather (minutes)" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding WeatherRefreshMinutes}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Default exposure (seconds)" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding DefaultExposureSeconds}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Default frame count" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding DefaultFrameCount}" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock Text="Fallback location name" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding DefaultLocationName}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Border Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="NIGHT DISPLAY" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="Display mode" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding NightModes}" SelectedItem="{Binding SelectedNightMode}" />
                                    <TextBlock Text="Full red mode removes blue and green from AstroDesk's UI palette and tints only the laptop preview. It never changes phone output."
                                               Style="{StaticResource MutedText}"
                                               Margin="0,10,0,0" />
                                    <TextBlock Text="Overlay opacity" Style="{StaticResource FieldLabel}" />
                                    <Slider Minimum="0.1" Maximum="1" Value="{Binding OverlayOpacity}" />
                                    <TextBlock Text="Overlay line thickness" Style="{StaticResource FieldLabel}" />
                                    <Slider Minimum="0.5" Maximum="6" Value="{Binding OverlayThickness}" />
                                    <TextBlock Text="Overlay color" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding OverlayColorOptions}"
                                              SelectedItem="{Binding OverlayColorName}" />
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Rectangle width %" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding CustomRectangleWidthPercent}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Rectangle height %" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding CustomRectangleHeightPercent}" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock Text="Histogram update (milliseconds)" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding HistogramUpdateMilliseconds}" />
                                    <CheckBox Content="Show coordinate-mapping debug overlay"
                                              IsChecked="{Binding DebugOverlay}"
                                              Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="EXPERIMENTAL CAPTURE CONTROL" Style="{StaticResource SectionTitle}" />
                                    <Border Background="{DynamicResource AccentMutedBrush}"
                                            BorderBrush="{DynamicResource WarningBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10">
                                        <TextBlock Text="Experimental: sends ADB taps to a configured Samsung Camera shutter coordinate. Verify coordinates with a harmless test; screen layout changes can make them wrong." />
                                    </Border>
                                    <CheckBox Content="Enable experimental capture controls"
                                              IsChecked="{Binding EnableExperimentalCaptureControls}"
                                              Margin="0,10,0,0" />
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Shutter X" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding ExperimentalShutterX}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Shutter Y" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding ExperimentalShutterY}" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <CheckBox Content="Tap shutter at each exposure-timer frame"
                                              IsChecked="{Binding ExperimentalTimerCapture}"
                                              Margin="0,10,0,0" />
                                    <Button Content="Send one test tap"
                                            Command="{Binding ExperimentalShutterTapCommand}"
                                            Style="{StaticResource ToolbarButton}"
                                            HorizontalAlignment="Left"
                                            Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelCard}">
                                <StackPanel>
                                    <TextBlock Text="KEYBOARD SHORTCUTS" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="F8  +1 frame" />
                                    <TextBlock Text="F9  Hide all overlays" Margin="0,5,0,0" />
                                    <TextBlock Text="F10  Cycle night mode" Margin="0,5,0,0" />
                                    <TextBlock Text="F11  Fullscreen preview" Margin="0,5,0,0" />
                                    <TextBlock Text="Ctrl+Shift+S  Preview screenshot" Margin="0,5,0,0" />
                                    <TextBlock Text="Shift+click / drag  Center or pan zoomed preview" Margin="0,5,0,0" />
                                    <TextBlock Text="Phone keyboard input is forwarded after clicking the embedded preview."
                                               Style="{StaticResource MutedText}"
                                               Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>

                            <Button Content="Save settings"
                                    Command="{Binding SaveSettingsCommand}"
                                    Style="{StaticResource AccentButton}"
                                    HorizontalAlignment="Right"
                                    Margin="0,12,0,0" />
                            <TextBlock Text="{Binding SettingsStatusText}"
                                       Style="{StaticResource MutedText}"
                                       HorizontalAlignment="Right"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid Panel.ZIndex="100"
                  Visibility="{Binding IsTimerFullscreen, Converter={StaticResource BoolToVisibility}}"
                  Background="Black">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TimerPhaseText}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="24"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding TimerCountdownText}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontFamily="Consolas"
                               FontSize="148"
                               FontWeight="Bold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding TimerFrameText}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="29"
                               HorizontalAlignment="Center" />
                    <WrapPanel HorizontalAlignment="Center" Margin="0,28,0,0">
                        <Button Content="Pause" Command="{Binding PauseTimerCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,8,0" />
                        <Button Content="Resume" Command="{Binding ResumeTimerCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,8,0" />
                        <Button Content="Stop" Command="{Binding StopTimerCommand}" Style="{StaticResource DangerButton}" Margin="0,0,8,0" />
                        <Button Content="Exit fullscreen" Command="{Binding ToggleTimerFullscreenCommand}" Style="{StaticResource AccentButton}" />
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1"
                           Text="{Binding ConnectionStatus}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="560" />
            </Grid>
        </Border>
    </Grid>
</Window>
