<Window x:Class="AstroDesk.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:AstroDesk.App.Controls"
        mc:Ignorable="d"
        Title="AstroDesk"
        Icon="Assets/AstroDesk.ico"
        Width="1400"
        Height="900"
        MinWidth="760"
        MinHeight="460"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_OnPreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <controls:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <controls:BooleanNegationConverter x:Key="BooleanNegation" />
    </Window.Resources>

    <!-- Three rows: header, workspace, status line. The code-behind collapses the
         header and status bar and zeroes their rows for fullscreen preview, so
         HeaderRow/StatusRow/AppHeader/StatusBar must keep these names. -->
    <Grid Background="{DynamicResource WorkspaceBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="HeaderRow" Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition x:Name="StatusRow" Height="24" />
        </Grid.RowDefinitions>

        <Border x:Name="AppHeader"
                Grid.Row="0"
                Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Image Width="28"
                           Height="28"
                           Source="Assets/AstroDeskLogo.png"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="0,0,10,0" />
                    <TextBlock Text="ASTRODESK"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Shoot"
                            Command="{Binding ShowDashboardCommand}"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TouchNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDashboard}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PanelRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="History"
                            Command="{Binding ShowHistoryCommand}"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TouchNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHistory}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PanelRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Stack"
                            Command="{Binding ShowStackingCommand}"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TouchNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStacking}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PanelRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Settings"
                            Command="{Binding ShowSettingsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TouchNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSettings}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PanelRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Right side: connection at a glance, and the night-mode switch.
                     Night mode used to be reachable only through Settings or F10,
                     which is the wrong place for the control you reach for the
                     moment you step outside. -->
                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Style="{StaticResource StatusPill}"
                            Padding="11,6"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8"
                                     Height="8"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource SecondaryTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DeviceConnected}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding DeviceModel}"
                                       MaxWidth="120"
                                       FontSize="12.5"
                                       ToolTip="{Binding DeviceModel}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Button Command="{Binding CycleNightModeCommand}"
                            Style="{StaticResource TouchNavButton}"
                            MinWidth="112"
                            ToolTip="Cycle display mode — normal dark, dim, full red (F10)">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10"
                                     Height="10"
                                     Margin="0,0,8,0"
                                     Fill="{DynamicResource AccentBrush}"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SelectedNightMode}"
                                       VerticalAlignment="Center"
                                       FontSize="13" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">

            <!-- ============================ SHOOT ============================
                 Instrument layout: a telemetry bar across the top, permanently
                 docked data rails either side, the preview in the middle, and
                 controls along the bottom. Nothing that matters is behind a
                 drawer — the panel is meant to be read at a glance, not
                 explored. -->
            <Grid Visibility="{Binding IsDashboard, Converter={StaticResource BoolToVisibility}}">
                <Grid Visibility="{Binding IsPreviewFullscreen, Converter={StaticResource InverseBoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Telemetry bar. Fixed-width cells in a WrapPanel: a reading
                         must never be clipped mid-glyph, so when the window is too
                         narrow the row reflows rather than squeezing. -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <WrapPanel Margin="12,8,12,4" Orientation="Horizontal">
                            <WrapPanel.Resources>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Width" Value="126" />
                                    <Setter Property="Margin" Value="0,0,8,6" />
                                </Style>
                            </WrapPanel.Resources>

                            <StackPanel Width="182">
                                <TextBlock Text="SHOOTING SCORE" Style="{StaticResource TelemetryLabel}" />
                                <TextBlock Text="{Binding ShootingScoreText}"
                                           Style="{StaticResource TelemetryValue}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Margin="0,3,0,0" />
                                <TextBlock Text="{Binding ShootingRecommendationText}"
                                           Style="{StaticResource TelemetrySub}"
                                           Margin="0,2,0,0"
                                           ToolTip="{Binding ShootingRecommendationText}" />
                                <TextBlock Text="{Binding WeatherScoreText}"
                                           Style="{StaticResource TelemetrySub}"
                                           FontSize="9.5"
                                           Margin="0,1,0,0"
                                           Visibility="{Binding IsSkyLimited, Converter={StaticResource BoolToVisibility}}"
                                           Foreground="{DynamicResource WarningBrush}"
                                           ToolTip="The weather would allow a better night; sky brightness is the limit." />
                            </StackPanel>

                            <StackPanel Width="148">
                                <TextBlock Text="SHOOTING WINDOW" Style="{StaticResource TelemetryLabel}" />
                                <TextBlock Text="{Binding BestShootingWindowText}"
                                           Style="{StaticResource TelemetryValue}"
                                           FontSize="15"
                                           Margin="0,4,0,0"
                                           ToolTip="{Binding BestShootingWindowText}" />
                                <TextBlock Text="{Binding DarkSkyWindowText, StringFormat=DARK {0}}"
                                           Style="{StaticResource TelemetrySub}"
                                           Margin="0,2,0,0" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="CLOUD" Style="{StaticResource TelemetryLabel}" />
                                <TextBlock Text="{Binding CloudCoverText}" Style="{StaticResource TelemetryValue}" Margin="0,3,0,0" />
                                <TextBlock Text="{Binding VisibilityText, StringFormat=VIS {0}}" Style="{StaticResource TelemetrySub}" Margin="0,2,0,0" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="TEMP" Style="{StaticResource TelemetryLabel}" />
                                <TextBlock Text="{Binding TemperatureText}" Style="{StaticResource TelemetryValue}" Margin="0,3,0,0" />
                                <TextBlock Text="{Binding HumidityText, StringFormat=HUM {0}}" Style="{StaticResource TelemetrySub}" Margin="0,2,0,0" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="DEW POINT" Style="{StaticResource TelemetryLabel}" />
                                <TextBlock Text="{Binding DewPointText}" Style="{StaticResource TelemetryValue}" Margin="0,3,0,0" />
                                <TextBlock Text="{Binding DewRiskText, StringFormat=RISK {0}}" Style="{StaticResource TelemetrySub}" Margin="0,2,0,0" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="WIND" Style="{StaticResource TelemetryLabel}" />
                                <TextBlock Text="{Binding WindText}" Style="{StaticResource TelemetryValue}" Margin="0,3,0,0" />
                                <TextBlock Text="{Binding PrecipitationText, StringFormat=RAIN {0}}" Style="{StaticResource TelemetrySub}" Margin="0,2,0,0" />
                            </StackPanel>

                            <!-- Sky darkness sits beside the weather readings because it is
                                 measured like them, and it is what caps the score for a
                                 faint target however good the weather is. -->
                            <!-- Wider gutter than its neighbours: the mag/arcsec² reading
                                 fills this cell edge to edge, so the default 8 leaves it
                                 touching the moon phase beside it. -->
                            <StackPanel Width="176" Margin="0,0,20,6">
                                <TextBlock Text="SKY DARKNESS" Style="{StaticResource TelemetryLabel}" />
                                <TextBlock Text="{Binding SkyDarknessText}"
                                           Style="{StaticResource TelemetryValue}"
                                           Foreground="{DynamicResource WarningBrush}"
                                           Margin="0,3,0,0" />
                                <TextBlock Text="{Binding LightPollutionText}"
                                           Style="{StaticResource TelemetrySub}"
                                           Margin="0,2,0,0"
                                           ToolTip="{Binding LightPollutionDetailText}" />
                                <TextBlock Text="{Binding SkyLimitText}"
                                           Style="{StaticResource TelemetrySub}"
                                           FontSize="9"
                                           Foreground="{DynamicResource WarningBrush}"
                                           Visibility="{Binding IsSkyLimited, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="MOON" Style="{StaticResource TelemetryLabel}" />
                                <TextBlock Text="{Binding MoonIlluminationText}" Style="{StaticResource TelemetryValue}" Margin="0,3,0,0" />
                                <TextBlock Text="{Binding MoonPhaseText}" Style="{StaticResource TelemetrySub}" Margin="0,2,0,0" ToolTip="{Binding MoonPhaseText}" />
                            </StackPanel>
                        </WrapPanel>
                    </Border>

                    <!-- Body: left rail, preview, right rail. -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="238" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="268" />
                        </Grid.ColumnDefinitions>

                        <!-- LEFT RAIL — session and capture state. -->
                        <Border Grid.Column="0"
                                Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="0,0,1,0">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          PanningMode="VerticalFirst"
                                          PanningDeceleration="0.001"
                                          PanningRatio="1">
                                <StackPanel Margin="13,12,13,12">
                                    <TextBlock Text="SESSION" Style="{StaticResource RailHeader}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="19" />
                                            <RowDefinition Height="19" />
                                            <RowDefinition Height="19" />
                                            <RowDefinition Height="19" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="State" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SessionStateText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Frames" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FrameCountText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Elapsed" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SessionElapsedText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Remaining" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding EstimatedRemainingText}" Style="{StaticResource RailValue}" />
                                    </Grid>
                                    <ProgressBar Value="{Binding FrameProgress}"
                                                 Minimum="0"
                                                 Maximum="1"
                                                 Height="4"
                                                 Margin="0,9,0,3" />
                                    <TextBlock Text="{Binding FrameProgressText}"
                                               Style="{StaticResource TelemetrySub}"
                                               HorizontalAlignment="Right" />

                                    <UniformGrid Columns="2" Margin="0,10,0,0">
                                        <Button Content="+1" Command="{Binding AddFrameCommand}" Style="{StaticResource PanelButton}" Margin="0,0,4,4" ToolTip="Add frame (F8)" />
                                        <Button Content="−1" Command="{Binding RemoveFrameCommand}" Style="{StaticResource PanelButton}" Margin="0,0,0,4" />
                                        <Button Content="Start" Command="{Binding StartSessionCommand}" Style="{StaticResource PanelButton}" Margin="0,0,4,4" />
                                        <Button Content="End" Command="{Binding EndSessionCommand}" Style="{StaticResource PanelButton}" Margin="0,0,0,4" />
                                        <Button Content="Pause" Command="{Binding PauseSessionCommand}" Style="{StaticResource PanelButton}" Margin="0,0,4,0" />
                                        <Button Content="Resume" Command="{Binding ResumeSessionCommand}" Style="{StaticResource PanelButton}" />
                                    </UniformGrid>

                                    <Border Style="{StaticResource Hairline}" />

                                    <TextBlock Text="CAPTURE" Style="{StaticResource RailHeader}" />
                                    <TextBlock Text="Target" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,3" />
                                    <TextBox Text="{Binding TargetName}" MinHeight="30" Padding="7,5" FontSize="12" Margin="0,0,0,6" />
                                    <TextBlock Text="Type" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,3" />
                                    <ComboBox ItemsSource="{Binding SessionTypes}" SelectedItem="{Binding SelectedSessionType}" MinHeight="30" FontSize="12" Margin="0,0,0,6" />
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,4,6">
                                            <TextBlock Text="ISO" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,3" />
                                            <TextBox Text="{Binding Iso}" MinHeight="30" Padding="7,5" FontSize="12" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,6">
                                            <TextBlock Text="Exp (s)" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,3" />
                                            <TextBox Text="{Binding ExposureSeconds}" MinHeight="30" Padding="7,5" FontSize="12" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,4,6">
                                            <TextBlock Text="Planned" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,3" />
                                            <TextBox Text="{Binding PlannedFrameCount}" MinHeight="30" Padding="7,5" FontSize="12" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,6">
                                            <TextBlock Text="Focus" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,3" />
                                            <TextBox Text="{Binding FocusSetting}" MinHeight="30" Padding="7,5" FontSize="12" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock Text="White balance" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,3" />
                                    <TextBox Text="{Binding WhiteBalance}" MinHeight="30" Padding="7,5" FontSize="12" Margin="0,0,0,6" />
                                    <TextBlock Text="Lens" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,3" />
                                    <ComboBox ItemsSource="{Binding PhoneLensOptions}" SelectedItem="{Binding SelectedPhoneLens}" MinHeight="30" FontSize="12" Margin="0,0,0,6" />
                                    <CheckBox Content="RAW" IsChecked="{Binding RawEnabled}" FontSize="12" MinHeight="26" />

                                    <Border Style="{StaticResource Hairline}" />

                                    <TextBlock Text="EXPOSURE TIMER" Style="{StaticResource RailHeader}" />
                                    <TextBlock Text="{Binding TimerCountdownText}"
                                               FontFamily="Cascadia Mono, Consolas"
                                               FontSize="26"
                                               HorizontalAlignment="Center"
                                               TextOptions.TextFormattingMode="Display" />
                                    <TextBlock Text="{Binding TimerPhaseText}"
                                               Style="{StaticResource TelemetrySub}"
                                               HorizontalAlignment="Center"
                                               Margin="0,1,0,8" />
                                    <UniformGrid Columns="3">
                                        <StackPanel Margin="0,0,4,6">
                                            <TextBlock Text="Frames" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,3" />
                                            <TextBox Text="{Binding TimerFrameCount}" MinHeight="30" Padding="5,5" FontSize="12" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,4,6">
                                            <TextBlock Text="Exp" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,3" />
                                            <TextBox Text="{Binding TimerExposureSeconds}" MinHeight="30" Padding="5,5" FontSize="12" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,6">
                                            <TextBlock Text="Gap" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,3" />
                                            <TextBox Text="{Binding TimerDelaySeconds}" MinHeight="30" Padding="5,5" FontSize="12" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="6" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Start delay (s)" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,3" />
                                            <TextBox Text="{Binding TimerInitialDelaySeconds}" MinHeight="30" Padding="7,5" FontSize="12" />
                                        </StackPanel>
                                        <CheckBox Grid.Column="2"
                                                  Content="Beep"
                                                  IsChecked="{Binding TimerSound}"
                                                  FontSize="11.5"
                                                  VerticalAlignment="Bottom"
                                                  MinHeight="30"
                                                  ToolTip="Sound on each frame" />
                                    </Grid>
                                    <UniformGrid Columns="2">
                                        <Button Content="Run" Command="{Binding StartTimerCommand}" Style="{StaticResource PanelButton}" Margin="0,0,4,4" />
                                        <Button Content="Stop" Command="{Binding StopTimerCommand}" Style="{StaticResource PanelButton}" Margin="0,0,0,4" />
                                        <Button Content="Pause" Command="{Binding PauseTimerCommand}" Style="{StaticResource PanelButton}" Margin="0,0,4,0" />
                                        <Button Content="Full" Command="{Binding ToggleTimerFullscreenCommand}" Style="{StaticResource PanelButton}" />
                                    </UniformGrid>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- PREVIEW -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <controls:AspectRatioDecorator Grid.Row="0"
                                                           AspectRatio="2.1444444444"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="12">
                                <Border Background="{DynamicResource PreviewBackgroundBrush}"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        ClipToBounds="True">
                                    <Grid>
                                        <controls:PhonePreviewControl x:Name="PhonePreview"
                                                                      controls:TouchScrollBehavior.IsExcluded="True"
                                                                      IsHitTestVisible="False"
                                                                      Source="{Binding PreviewImage}"
                                                                      RuleOfThirds="{Binding RuleOfThirds}"
                                                                      Crosshair="{Binding Crosshair}"
                                                                      DiagonalGuides="{Binding DiagonalGuides}"
                                                                      SafeArea="{Binding SafeArea}"
                                                                      HorizonLine="{Binding HorizonLine}"
                                                                      CustomRectangle="{Binding CustomRectangle}"
                                                                      CircleOverlay="{Binding CircleOverlay}"
                                                                      CustomRectangleWidthPercent="{Binding CustomRectangleWidthPercent}"
                                                                      CustomRectangleHeightPercent="{Binding CustomRectangleHeightPercent}"
                                                                      OverlayBrush="{Binding OverlayBrush}"
                                                                      OverlayOpacity="{Binding OverlayOpacity}"
                                                                      OverlayThickness="{Binding OverlayThickness}"
                                                                      ZoomScale="1"
                                                                      ZoomCenter="{Binding ZoomCenter}"
                                                                      FocusMagnifier="{Binding FocusMagnifier}"
                                                                      IsFrozen="{Binding IsPreviewFrozen}"
                                                                      PixelPerfect="{Binding PixelPerfect}"
                                                                      ErrorText="{Binding PreviewError}"
                                                                      StatusText="{Binding PreviewStatus}"
                                                                      DebugOverlay="{Binding DebugOverlay}"
                                                                      DebugText="{Binding DebugOverlayText}"
                                                                      Rotation="{Binding PreviewRotation}"
                                                                      ScrcpyClientSize="{Binding ScrcpyClientSize}" />
                                        <!-- NativeScrcpyHost is an HwndHost holding scrcpy's own window,
                                             reparented into the layout. Do not wrap this in a container
                                             whose Visibility toggles: collapsing it runs DestroyWindowCore,
                                             which destroys the reparented window and takes the scrcpy
                                             process down with it. WPF also cannot draw over a native child
                                             window, so framing overlays are invisible while this is shown;
                                             showing them requires parking scrcpy's window off-screen and
                                             falling back to the captured-frame preview, not hiding the host. -->
                                        <controls:NativeScrcpyHost SourceWindowHandle="{Binding MainScrcpyWindowHandle}"
                                                                   Visibility="{Binding ShowWirelessPanel, Converter={StaticResource InverseBoolToVisibility}}"
                                                                   controls:TouchScrollBehavior.IsExcluded="True" />
                                    </Grid>
                                </Border>
                            </controls:AspectRatioDecorator>

                            <!-- Framing strip: overlays are toggled while looking at
                                 the preview, so they belong directly beneath it. -->
                            <Border Grid.Row="1"
                                    Background="{DynamicResource PanelBackgroundBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="12,7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <WrapPanel Orientation="Horizontal">
                                        <TextBlock Text="OVERLAYS" Style="{StaticResource TelemetryLabel}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <CheckBox Content="Thirds" IsChecked="{Binding RuleOfThirds}" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,9,0" />
                                        <CheckBox Content="Cross" IsChecked="{Binding Crosshair}" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,9,0" />
                                        <CheckBox Content="Diag" IsChecked="{Binding DiagonalGuides}" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,9,0" />
                                        <CheckBox Content="Safe" IsChecked="{Binding SafeArea}" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,9,0" />
                                        <CheckBox Content="Horizon" IsChecked="{Binding HorizonLine}" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,9,0" />
                                        <CheckBox Content="Rect" IsChecked="{Binding CustomRectangle}" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,9,0" />
                                        <CheckBox Content="Circle" IsChecked="{Binding CircleOverlay}" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,9,0" />
                                        <CheckBox Content="Loupe" IsChecked="{Binding FocusMagnifier}" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    </WrapPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="Hide all" Command="{Binding HideAllOverlaysCommand}" Style="{StaticResource PanelButton}" MinHeight="28" Padding="9,3" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- RIGHT RAIL — sky, site, and device telemetry. -->
                        <Border Grid.Column="2" Style="{StaticResource RailPanel}">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          PanningMode="VerticalFirst"
                                          PanningDeceleration="0.001"
                                          PanningRatio="1">
                                <StackPanel Margin="13,12,13,12">
                                    <DockPanel LastChildFill="False" Margin="0,0,0,7">
                                        <TextBlock Text="SKY" Style="{StaticResource RailHeader}" Margin="0" />
                                        <Button DockPanel.Dock="Right"
                                                Content="↻"
                                                Command="{Binding RefreshConditionsCommand}"
                                                Style="{StaticResource PanelButton}"
                                                MinHeight="22"
                                                MinWidth="26"
                                                Padding="4,0"
                                                FontSize="12"
                                                ToolTip="Refresh conditions" />
                                    </DockPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Phase" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MoonPhaseText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="1" Text="Position" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MoonPositionText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="2" Text="Moonrise" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MoonriseText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="3" Text="Moonset" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MoonsetText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="4" Text="Light poll." Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LightPollutionText}" Style="{StaticResource RailValue}" />
                                    </Grid>

                                    <Border Style="{StaticResource Hairline}" />

                                    <TextBlock Text="TWILIGHT" Style="{StaticResource RailHeader}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Sunset" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SunsetText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="1" Text="Astro dusk" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AstronomicalDuskText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="2" Text="Astro dawn" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AstronomicalDawnText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="3" Text="Sunrise" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SunriseText}" Style="{StaticResource RailValue}" />
                                    </Grid>

                                    <Border Style="{StaticResource Hairline}" />

                                    <DockPanel LastChildFill="False" Margin="0,0,0,7">
                                        <TextBlock Text="SITE" Style="{StaticResource RailHeader}" Margin="0" />
                                        <Button DockPanel.Dock="Right"
                                                Content="Locate"
                                                Command="{Binding LocateCurrentUserCommand}"
                                                Style="{StaticResource PanelButton}"
                                                MinHeight="24"
                                                Padding="8,2"
                                                FontSize="11" />
                                    </DockPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Location" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LocationStatusText}" Style="{StaticResource RailValue}" ToolTip="{Binding LocationStatusText}" />
                                        <TextBlock Grid.Row="1" Text="Coords" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LocationCoordinateText}" Style="{StaticResource RailValue}" ToolTip="{Binding LocationCoordinateText}" />
                                        <TextBlock Grid.Row="2" Text="Altitude" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AltitudeText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="3" Text="Time zone" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TimeZoneText}" Style="{StaticResource RailValue}" ToolTip="{Binding TimeZoneText}" />
                                    </Grid>
                                    <Grid Margin="0,7,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding LocationSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="28"
                                                 Padding="6,4"
                                                 FontSize="11.5"
                                                 ToolTip="Search for an observing site" />
                                        <Button Grid.Column="2"
                                                Content="Find"
                                                Command="{Binding SearchLocationsCommand}"
                                                Style="{StaticResource PanelButton}"
                                                MinHeight="28"
                                                Padding="8,3"
                                                FontSize="11" />
                                    </Grid>
                                    <ComboBox ItemsSource="{Binding Locations}"
                                              SelectedItem="{Binding SelectedLocation}"
                                              MinHeight="28"
                                              FontSize="11.5"
                                              Margin="0,5,0,0"
                                              ToolTip="Saved and searched observing sites" />

                                    <Border Style="{StaticResource Hairline}" />

                                    <TextBlock Text="DEVICE" Style="{StaticResource RailHeader}" />

                                    <!-- With more than one authorized device attached, scrcpy and every
                                         forwarded key need to know which one is the target. Without this
                                         picker the app can see the phones but cannot act on any of them. -->
                                    <!-- DisplayName is the model alone, so a phone attached over both
                                         USB and Wi-Fi appears twice as the same string. The serial is
                                         what actually distinguishes them: a wireless transport carries
                                         an "adb-...-tls-connect" serial, a cable carries the bare one. -->
                                    <ComboBox ItemsSource="{Binding AvailableAdbDevices}"
                                              SelectedItem="{Binding SelectedAdbDevice}"
                                              ToolTip="Select an Android device when more than one is connected"
                                              MinHeight="34"
                                              FontSize="12"
                                              Margin="0,0,0,7">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="12" />
                                                    <TextBlock Text="{Binding Serial}"
                                                               Style="{StaticResource TelemetrySub}"
                                                               FontSize="9.5"
                                                               MaxWidth="190"
                                                               ToolTip="{Binding Serial}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Text="{Binding ConnectionStatus}"
                                               Style="{StaticResource MutedText}"
                                               FontSize="10.5"
                                               Margin="0,0,0,7" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="18" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Model" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DeviceModel}" Style="{StaticResource RailValue}" ToolTip="{Binding DeviceModel}" />
                                        <TextBlock Grid.Row="1" Text="Battery" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BatteryText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="2" Text="Temp" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PhoneTemperatureText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="3" Text="Storage" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding StorageText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="4" Text="Screen" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ScreenResolutionText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="5" Text="Preview" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding PreviewFrameSizeText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="6" Text="USB" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding UsbStateText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="7" Text="Android" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding AndroidVersionText}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="8" Text="Camera" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding CameraName}" Style="{StaticResource RailValue}" />
                                        <TextBlock Grid.Row="9" Text="Orientation" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding OrientationText}" Style="{StaticResource RailValue}" />
                                    </Grid>

                                    <UniformGrid Columns="3" Margin="0,9,0,0">
                                        <Button Content="Home" Command="{Binding HomeCommand}" Style="{StaticResource PanelButton}" MinHeight="28" Padding="4,3" FontSize="11" Margin="0,0,3,3" />
                                        <Button Content="Back" Command="{Binding BackCommand}" Style="{StaticResource PanelButton}" MinHeight="28" Padding="4,3" FontSize="11" Margin="0,0,3,3" />
                                        <Button Content="Recent" Command="{Binding RecentAppsCommand}" Style="{StaticResource PanelButton}" MinHeight="28" Padding="4,3" FontSize="11" Margin="0,0,0,3" />
                                        <Button Content="Vol+" Command="{Binding VolumeUpCommand}" Style="{StaticResource PanelButton}" MinHeight="28" Padding="4,3" FontSize="11" Margin="0,0,3,3" />
                                        <Button Content="Vol−" Command="{Binding VolumeDownCommand}" Style="{StaticResource PanelButton}" MinHeight="28" Padding="4,3" FontSize="11" Margin="0,0,3,3" />
                                        <Button Content="Power" Command="{Binding PowerCommand}" Style="{StaticResource PanelButton}" MinHeight="28" Padding="4,3" FontSize="11" Margin="0,0,0,3" />
                                    </UniformGrid>
                                    <UniformGrid Columns="2">
                                        <Button Content="Keep awake" Command="{Binding KeepPhoneAwakeCommand}" Style="{StaticResource PanelButton}" MinHeight="28" Padding="4,3" FontSize="11" Margin="0,0,3,0" />
                                        <Button Content="Screen off" Command="{Binding TurnPhoneScreenOffCommand}" Style="{StaticResource PanelButton}" MinHeight="28" Padding="4,3" FontSize="11" />
                                    </UniformGrid>

                                    <Border Style="{StaticResource Hairline}" />

                                    <DockPanel LastChildFill="False" Margin="0,0,0,7">
                                        <TextBlock Text="HISTOGRAM" Style="{StaticResource RailHeader}" Margin="0" />
                                        <ToggleButton DockPanel.Dock="Right"
                                                      Content="Show"
                                                      IsChecked="{Binding ShowHistogram, Mode=TwoWay}"
                                                      Style="{StaticResource PanelToggleButton}"
                                                      MinHeight="24"
                                                      Padding="8,2"
                                                      FontSize="11" />
                                    </DockPanel>
                                    <StackPanel Visibility="{Binding ShowHistogram, Converter={StaticResource BoolToVisibility}}">
                                        <Border Background="{DynamicResource WindowBackgroundBrush}"
                                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="2"
                                                Padding="3">
                                            <Image Source="{Binding Histogram}" Height="56" Stretch="Fill" />
                                        </Border>
                                        <UniformGrid Columns="2" Margin="0,5,0,0">
                                            <CheckBox Content="On preview" IsChecked="{Binding HistogramOverlay}" FontSize="11.5" MinHeight="26" Margin="0,0,4,0" />
                                            <CheckBox Content="Freeze" IsChecked="{Binding HistogramFrozen}" FontSize="11.5" MinHeight="26" />
                                        </UniformGrid>
                                        <Grid Margin="0,3,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="17" />
                                                <RowDefinition Height="17" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="Shadow clip" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ShadowClippingText}" Style="{StaticResource RailValue}" />
                                            <TextBlock Grid.Row="1" Text="Highlight clip" Style="{StaticResource RailLabel}" Margin="0,0,10,0" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding HighlightClippingText}" Style="{StaticResource RailValue}" />
                                        </Grid>
                                    </StackPanel>

                                    <Border Style="{StaticResource Hairline}" />

                                    <TextBlock Text="NOTES" Style="{StaticResource RailHeader}" />
                                    <TextBox Text="{Binding SessionNotes, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="56"
                                             FontSize="12"
                                             Padding="7,5"
                                             Margin="0,0,0,5" />
                                    <Button Content="Save note"
                                            Command="{Binding SaveSessionNoteCommand}"
                                            Style="{StaticResource PanelButton}"
                                            MinHeight="28"
                                            FontSize="11" />

                                    <Border Style="{StaticResource Hairline}" />
                                    <TextBlock Text="{Binding ConditionsUpdatedText}"
                                               Style="{StaticResource MutedText}"
                                               FontSize="10.5" />
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- Control bar -->
                    <Border Grid.Row="2" Style="{StaticResource ControlBar}" Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <WrapPanel Orientation="Horizontal">
                                <Button Content="Start preview" Command="{Binding StartPreviewCommand}" Style="{StaticResource AccentButton}" MinHeight="34" Padding="12,6" Margin="0,0,6,0" />
                                <Button Content="Stop" Command="{Binding StopPreviewCommand}" Style="{StaticResource PanelButton}" MinHeight="34" Padding="10,6" Margin="0,0,6,0" />
                                <Button Content="Reconnect" Command="{Binding ReconnectPreviewCommand}" Style="{StaticResource PanelButton}" MinHeight="34" Padding="10,6" Margin="0,0,6,0" />
                                <Button Content="Screenshot" Command="{Binding TakeScreenshotCommand}" Style="{StaticResource PanelButton}" MinHeight="34" Padding="10,6" Margin="0,0,6,0" />
                                <Button Content="Copy frame" Command="{Binding CopyPreviewToClipboardCommand}" Style="{StaticResource PanelButton}" MinHeight="34" Padding="10,6" Margin="0,0,6,0" />
                                <ToggleButton Content="Freeze" IsChecked="{Binding IsPreviewFrozen, Mode=TwoWay}" Style="{StaticResource PanelToggleButton}" MinHeight="34" Padding="10,6" Margin="0,0,6,0" />
                                <Button Content="Paste" Command="{Binding PasteClipboardCommand}" Style="{StaticResource PanelButton}" MinHeight="34" Padding="10,6" Margin="0,0,6,0" ToolTip="Send clipboard text to the phone" />
                                <Button Content="Folder" Command="{Binding OpenScreenshotFolderCommand}" Style="{StaticResource PanelButton}" MinHeight="34" Padding="10,6" ToolTip="Open the screenshot folder" />
                            </WrapPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <TextBlock Text="{Binding PreviewFps, StringFormat=FPS {0:F1}}"
                                           Style="{StaticResource TelemetrySub}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <ToggleButton Content="Wireless" IsChecked="{Binding ShowWirelessPanel, Mode=TwoWay}" Style="{StaticResource PanelToggleButton}" MinHeight="34" Padding="10,6" Margin="0,0,6,0" />
                                <Button Content="Fullscreen" Command="{Binding TogglePreviewFullscreenCommand}" Style="{StaticResource PanelButton}" MinHeight="34" Padding="10,6" ToolTip="F11" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Wireless ADB overlay -->
                    <Border Grid.Row="1"
                            Panel.ZIndex="60"
                            Width="392"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Margin="0,0,268,0"
                            Style="{StaticResource PanelCard}"
                            Padding="0"
                            Visibility="{Binding ShowWirelessPanel, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="16,14,16,9" LastChildFill="False">
                                <StackPanel>
                                    <TextBlock Text="WIRELESS ADB" Style="{StaticResource RailHeader}" Margin="0" />
                                    <TextBlock Text="Connect the phone without a cable" Style="{StaticResource TelemetrySub}" Margin="0,2,0,0" />
                                </StackPanel>
                                <ToggleButton DockPanel.Dock="Right"
                                              Content="Close"
                                              IsChecked="{Binding ShowWirelessPanel, Mode=TwoWay}"
                                              Style="{StaticResource PanelToggleButton}"
                                              MinHeight="26"
                                              Padding="9,3"
                                              FontSize="11" />
                            </DockPanel>
                            <ScrollViewer Grid.Row="1"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          PanningMode="VerticalFirst"
                                          PanningDeceleration="0.001"
                                          PanningRatio="1">
                                <StackPanel Margin="16,0,16,16">
                                    <Border Background="{DynamicResource PanelRaisedBrush}"
                                            BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="1,0,0,0"
                                            CornerRadius="0"
                                            Padding="12"
                                            Margin="0,0,0,12"
                                            Visibility="{Binding IsWirelessQrActive, Converter={StaticResource InverseBoolToVisibility}}">
                                        <StackPanel>
                                            <TextBlock Text="FASTEST — USB TO WIRELESS" Style="{StaticResource TelemetryLabel}" Margin="0,0,0,5" />
                                            <TextBlock Text="Keep USB connected and authorized. AstroDesk finds the phone's Wi-Fi address and switches ADB automatically."
                                                       Style="{StaticResource MutedText}"
                                                       FontSize="11.5"
                                                       Margin="0,0,0,10" />
                                            <Button Content="Switch USB phone to wireless"
                                                    Command="{Binding SwitchUsbToWirelessCommand}"
                                                    Style="{StaticResource AccentButton}"
                                                    MinHeight="34"
                                                    IsEnabled="{Binding IsWirelessBusy, Converter={StaticResource BooleanNegation}}" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Visibility="{Binding IsWirelessQrActive, Converter={StaticResource InverseBoolToVisibility}}">
                                        <TextBlock Text="CONNECT DIRECTLY" Style="{StaticResource TelemetryLabel}" Margin="0,0,0,6" />
                                        <TextBox Text="{Binding WirelessEndpoint, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Example: 192.168.1.42:5555"
                                                 MinHeight="32"
                                                 FontSize="12"
                                                 Margin="0,0,0,7" />
                                        <UniformGrid Columns="2" Margin="0,0,0,12">
                                            <Button Content="Connect"
                                                    Command="{Binding ConnectWirelessCommand}"
                                                    Style="{StaticResource AccentButton}"
                                                    MinHeight="34"
                                                    Margin="0,0,5,0"
                                                    IsEnabled="{Binding IsWirelessBusy, Converter={StaticResource BooleanNegation}}" />
                                            <Button Content="Disconnect"
                                                    Command="{Binding DisconnectWirelessCommand}"
                                                    Style="{StaticResource PanelButton}"
                                                    MinHeight="34"
                                                    IsEnabled="{Binding IsWirelessBusy, Converter={StaticResource BooleanNegation}}" />
                                        </UniformGrid>
                                    </StackPanel>

                                    <TextBlock Text="PAIR WITH QR CODE" Style="{StaticResource TelemetryLabel}" Margin="0,0,0,6" />
                                    <Button Content="Show QR code"
                                            Command="{Binding StartQrPairingCommand}"
                                            Style="{StaticResource PanelButton}"
                                            MinHeight="34"
                                            Margin="0,0,0,9"
                                            Visibility="{Binding IsWirelessQrActive, Converter={StaticResource InverseBoolToVisibility}}"
                                            IsEnabled="{Binding IsWirelessBusy, Converter={StaticResource BooleanNegation}}" />
                                    <Button Content="Cancel QR pairing"
                                            Command="{Binding CancelQrPairingCommand}"
                                            Style="{StaticResource PanelButton}"
                                            MinHeight="34"
                                            Margin="0,0,0,9"
                                            Visibility="{Binding IsWirelessQrActive, Converter={StaticResource BoolToVisibility}}" />
                                    <Border Background="White"
                                            CornerRadius="2"
                                            Padding="7"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,12"
                                            Visibility="{Binding IsWirelessQrActive, Converter={StaticResource BoolToVisibility}}">
                                        <Image Source="{Binding WirelessQrCodeImage}"
                                               Width="240"
                                               Height="240"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                    </Border>

                                    <Expander Header="Pair with a six-digit code"
                                              Visibility="{Binding IsWirelessQrActive, Converter={StaticResource InverseBoolToVisibility}}">
                                        <StackPanel Margin="0,9,0,0">
                                            <TextBlock Text="On the phone: Settings → Developer options → Wireless debugging → Pair device with pairing code."
                                                       Style="{StaticResource MutedText}"
                                                       FontSize="11.5"
                                                       Margin="0,0,0,9" />
                                            <Button Content="Find pairing address automatically"
                                                    Command="{Binding FindPairingAddressCommand}"
                                                    Style="{StaticResource PanelButton}"
                                                    MinHeight="32"
                                                    IsEnabled="{Binding IsWirelessBusy, Converter={StaticResource BooleanNegation}}"
                                                    Margin="0,0,0,9" />
                                            <TextBlock Text="Pairing IP and port" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,3" />
                                            <TextBox Text="{Binding WirelessPairingEndpoint, UpdateSourceTrigger=PropertyChanged}"
                                                     MinHeight="32"
                                                     FontSize="12"
                                                     Margin="0,0,0,7" />
                                            <TextBlock Text="Six-digit pairing code" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,3" />
                                            <TextBox Text="{Binding WirelessPairingCode, UpdateSourceTrigger=PropertyChanged}"
                                                     MaxLength="6"
                                                     MinHeight="32"
                                                     FontSize="12"
                                                     Margin="0,0,0,7" />
                                            <Button Content="Pair phone"
                                                    Command="{Binding PairWirelessCommand}"
                                                    Style="{StaticResource AccentButton}"
                                                    MinHeight="34"
                                                    IsEnabled="{Binding IsWirelessBusy, Converter={StaticResource BooleanNegation}}" />
                                        </StackPanel>
                                    </Expander>

                                    <Border Background="{DynamicResource PanelRaisedBrush}"
                                            CornerRadius="2"
                                            Margin="0,12,0,0"
                                            Padding="10">
                                        <TextBlock Text="{Binding WirelessStatus}" TextWrapping="Wrap" FontSize="12" />
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Fullscreen preview -->
                <Grid Visibility="{Binding IsPreviewFullscreen, Converter={StaticResource BoolToVisibility}}"
                      Background="{DynamicResource PreviewBackgroundBrush}">
                    <controls:PhonePreviewControl x:Name="FullscreenPhonePreview"
                                                  controls:TouchScrollBehavior.IsExcluded="True"
                                                  IsHitTestVisible="False"
                                                  Source="{Binding PreviewImage}"
                                                  RuleOfThirds="{Binding RuleOfThirds}"
                                                  Crosshair="{Binding Crosshair}"
                                                  DiagonalGuides="{Binding DiagonalGuides}"
                                                  SafeArea="{Binding SafeArea}"
                                                  HorizonLine="{Binding HorizonLine}"
                                                  CustomRectangle="{Binding CustomRectangle}"
                                                  CircleOverlay="{Binding CircleOverlay}"
                                                  CustomRectangleWidthPercent="{Binding CustomRectangleWidthPercent}"
                                                  CustomRectangleHeightPercent="{Binding CustomRectangleHeightPercent}"
                                                  OverlayBrush="{Binding OverlayBrush}"
                                                  OverlayOpacity="{Binding OverlayOpacity}"
                                                  OverlayThickness="{Binding OverlayThickness}"
                                                  ZoomScale="1"
                                                  ZoomCenter="{Binding ZoomCenter}"
                                                  FocusMagnifier="{Binding FocusMagnifier}"
                                                  IsFrozen="{Binding IsPreviewFrozen}"
                                                  PixelPerfect="{Binding PixelPerfect}"
                                                  ErrorText="{Binding PreviewError}"
                                                  StatusText="{Binding PreviewStatus}"
                                                  DebugOverlay="{Binding DebugOverlay}"
                                                  DebugText="{Binding DebugOverlayText}"
                                                  Rotation="{Binding PreviewRotation}"
                                                  ScrcpyClientSize="{Binding ScrcpyClientSize}" />
                    <controls:NativeScrcpyHost SourceWindowHandle="{Binding FullscreenScrcpyWindowHandle}"
                                               controls:TouchScrollBehavior.IsExcluded="True" />
                    <Button Content="Exit fullscreen"
                            Command="{Binding TogglePreviewFullscreenCommand}"
                            Style="{StaticResource PanelButton}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="16"
                            Opacity="0.7" />
                </Grid>
            </Grid>


            <!-- =========================== HISTORY =========================== -->
            <Grid Visibility="{Binding IsHistory, Converter={StaticResource BoolToVisibility}}"
                  Margin="18,16,18,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Session history" Style="{StaticResource PageTitle}" />
                    <TextBlock Text="Review nights, compare results, and reuse the plans that worked."
                               Style="{StaticResource PageSubtitle}" />
                </StackPanel>

                <Border Grid.Row="2" Style="{StaticResource PanelCard}" Padding="16">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Search sessions" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding HistorySearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Search target, location, problems, and notes" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Session type" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding HistoryTypeFilters}"
                                          SelectedItem="{Binding SelectedHistoryTypeFilter}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Sort by" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding HistorySortOptions}"
                                          SelectedItem="{Binding SelectedHistorySort}" />
                            </StackPanel>
                            <Button Grid.Column="6"
                                    Content="Apply"
                                    Command="{Binding RefreshHistoryCommand}"
                                    Style="{StaticResource PrimaryTouchButton}"
                                    VerticalAlignment="Bottom"
                                    MinWidth="96" />
                        </Grid>
                        <Expander Header="More filters" Margin="0,12,0,0">
                            <WrapPanel Margin="0,10,0,0">
                                <StackPanel Width="185" Margin="0,0,12,10">
                                    <TextBlock Text="Target" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding HistoryTargetFilter}" />
                                </StackPanel>
                                <StackPanel Width="185" Margin="0,0,12,10">
                                    <TextBlock Text="Location" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding HistoryLocationFilter}" />
                                </StackPanel>
                                <StackPanel Width="150" Margin="0,0,12,10">
                                    <TextBlock Text="From" Style="{StaticResource FieldLabel}" />
                                    <DatePicker SelectedDate="{Binding HistoryFromDate}" />
                                </StackPanel>
                                <StackPanel Width="150" Margin="0,0,12,10">
                                    <TextBlock Text="To" Style="{StaticResource FieldLabel}" />
                                    <DatePicker SelectedDate="{Binding HistoryToDate}" />
                                </StackPanel>
                                <StackPanel Width="130" Margin="0,0,12,10">
                                    <TextBlock Text="Minimum rating" Style="{StaticResource FieldLabel}" />
                                    <ComboBox ItemsSource="{Binding HistoryRatingOptions}"
                                              SelectedItem="{Binding HistoryMinimumRating}" />
                                </StackPanel>
                                <Button Content="Clear"
                                        Style="{StaticResource TouchButton}"
                                        Click="ClearHistoryDates_OnClick"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,0,10" />
                            </WrapPanel>
                        </Expander>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource PanelCard}" Padding="8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Bottom"
                                       Text="{Binding HistoryStatusText}"
                                       Style="{StaticResource MutedText}"
                                       Margin="8" />
                            <ListBox ItemsSource="{Binding History}"
                                     SelectedItem="{Binding SelectedHistorySession}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid MinHeight="56">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Target}" FontWeight="SemiBold" FontSize="15" />
                                                <TextBlock Text="{Binding Summary}" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                                                <TextBlock Text="{Binding DateText}" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FramesText}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding RatingText}" Foreground="{DynamicResource WarningBrush}" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PanelCard}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ScrollViewer Grid.Row="0"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          PanningMode="VerticalFirst"
                                          PanningDeceleration="0.001"
                                          PanningRatio="1">
                                <ScrollViewer.Style>
                                    <Style TargetType="ScrollViewer">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedHistorySession}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ScrollViewer.Style>
                                <StackPanel Margin="18" DataContext="{Binding SelectedHistorySession}">
                                    <DockPanel>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Target}" FontSize="23" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding DateText}" Style="{StaticResource MutedText}" />
                                        </StackPanel>
                                        <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding RatingText}" Foreground="{DynamicResource WarningBrush}" FontSize="17" />
                                            <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </DockPanel>
                                    <Border Style="{StaticResource SeparatorLine}" />
                                    <UniformGrid Columns="4">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="TYPE" Style="{StaticResource CardLabel}" />
                                            <TextBlock Text="{Binding Type}" Style="{StaticResource MetricValue}" Margin="0,4,0,0" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="DURATION" Style="{StaticResource CardLabel}" />
                                            <TextBlock Text="{Binding DurationText}" Style="{StaticResource MetricValue}" Margin="0,4,0,0" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="FRAMES" Style="{StaticResource CardLabel}" />
                                            <TextBlock Text="{Binding FramesText}" Style="{StaticResource MetricValue}" Margin="0,4,0,0" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="INTEGRATION" Style="{StaticResource CardLabel}" />
                                            <TextBlock Text="{Binding IntegrationText}" Style="{StaticResource MetricValue}" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <Border Style="{StaticResource SeparatorLine}" />
                                    <TextBlock Text="CONDITIONS" Style="{StaticResource CardLabel}" Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding ConditionsSummary}" TextWrapping="Wrap" />
                                    <TextBlock Text="CAPTURE SETTINGS" Style="{StaticResource CardLabel}" Margin="0,16,0,6" />
                                    <TextBlock Text="{Binding SettingsSummary}" TextWrapping="Wrap" />
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="BATTERY" Style="{StaticResource CardLabel}" Margin="0,0,0,6" />
                                            <TextBlock Text="{Binding BatterySummary}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="FREE STORAGE" Style="{StaticResource CardLabel}" Margin="0,0,0,6" />
                                            <TextBlock Text="{Binding StorageSummary}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="TIMELINE &amp; NOTES" Style="{StaticResource CardLabel}" Margin="0,18,0,6" />
                                    <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="8" Padding="12">
                                        <TextBlock Text="{Binding NotesText}" TextWrapping="Wrap" />
                                    </Border>
                                    <TextBlock Text="PREVIEW SCREENSHOTS" Style="{StaticResource CardLabel}" Margin="0,18,0,6" />
                                    <ItemsControl ItemsSource="{Binding ScreenshotPaths}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="6" Padding="9" Margin="0,0,0,5">
                                                    <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" ToolTip="{Binding}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>

                            <TextBlock Grid.Row="0"
                                       Text="Select a session to inspect its conditions, capture settings, notes, screenshots, and device usage."
                                       FontSize="14"
                                       MaxWidth="430"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedHistorySession}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Border Grid.Row="1"
                                    Background="{DynamicResource PanelBackgroundBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedHistorySession}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBox Text="{Binding HistoryEditProblems, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Edit problems / outcome notes"
                                             MinHeight="38"
                                             Margin="0,0,0,10" />
                                    <DockPanel>
                                        <WrapPanel>
                                            <Button Content="Start plan" Command="{Binding StartSelectedPlanCommand}" Style="{StaticResource PrimaryTouchButton}" Margin="0,0,6,0" />
                                            <Button Content="Duplicate" Command="{Binding DuplicateSelectedSessionCommand}" Style="{StaticResource TouchButton}" Margin="0,0,6,0" />
                                            <Button Content="Export JSON" Command="{Binding ExportSelectedJsonCommand}" Style="{StaticResource TouchButton}" Margin="0,0,6,0" />
                                            <Button Content="Export MD" Command="{Binding ExportSelectedMarkdownCommand}" Style="{StaticResource TouchButton}" />
                                        </WrapPanel>
                                        <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                            <ComboBox Width="64"
                                                      ItemsSource="{Binding RatingOptions}"
                                                      SelectedItem="{Binding HistoryEditRating}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,6,0"
                                                      ToolTip="Rating" />
                                            <Button Content="Save" Command="{Binding SaveHistoryEditsCommand}" Style="{StaticResource TouchButton}" Margin="0,0,6,0" />
                                            <Button Content="Delete" Command="{Binding DeleteSelectedSessionCommand}" Style="{StaticResource DangerButton}" MinHeight="48" Padding="18,11" />
                                        </WrapPanel>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- =========================== SETTINGS ========================== -->
            <Grid Visibility="{Binding IsSettings, Converter={StaticResource BoolToVisibility}}"
                  Margin="18,16,18,16">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              PanningMode="VerticalFirst"
                              PanningDeceleration="0.001"
                              PanningRatio="1">
                    <StackPanel MaxWidth="1240" HorizontalAlignment="Center">
                        <TextBlock Text="Settings" Style="{StaticResource PageTitle}" />
                        <TextBlock Text="Tune the field workflow without cluttering the shooting screen."
                                   Style="{StaticResource PageSubtitle}" />
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <Border Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="ANDROID TOOLS" Style="{StaticResource CardLabel}" Margin="0,0,0,10" />
                                        <TextBlock Text="ADB executable" Style="{StaticResource FieldLabel}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding AdbPath}" />
                                            <Button Grid.Column="2" Content="Browse…" Click="BrowseAdb_OnClick" Style="{StaticResource TouchButton}" />
                                        </Grid>
                                        <TextBlock Text="siril-cli executable (stacking)" Style="{StaticResource FieldLabel}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding SirilPath}" />
                                            <Button Grid.Column="2" Content="Browse…" Click="BrowseSiril_OnClick" Style="{StaticResource TouchButton}" />
                                        </Grid>
                                        <TextBlock Text="scrcpy executable" Style="{StaticResource FieldLabel}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding ScrcpyPath}" />
                                            <Button Grid.Column="2" Content="Browse…" Click="BrowseScrcpy_OnClick" Style="{StaticResource TouchButton}" />
                                        </Grid>
                                        <UniformGrid Columns="3" Margin="0,8,0,0">
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Bitrate (Mbps)" Style="{StaticResource FieldLabel}" />
                                                <TextBox Text="{Binding ScrcpyBitrateMbps}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Max resolution" Style="{StaticResource FieldLabel}" />
                                                <TextBox Text="{Binding ScrcpyMaxResolution}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Max FPS" Style="{StaticResource FieldLabel}" />
                                                <TextBox Text="{Binding ScrcpyMaxFps}" />
                                            </StackPanel>
                                        </UniformGrid>
                                        <CheckBox Content="Automatically launch scrcpy at startup"
                                                  IsChecked="{Binding AutomaticallyLaunchScrcpy}"
                                                  Margin="0,12,0,0"
                                                  MinHeight="32" />
                                        <CheckBox Content="Automatically reconnect ADB"
                                                  IsChecked="{Binding AutomaticallyReconnect}"
                                                  MinHeight="32" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="FILES &amp; LOCAL DATA" Style="{StaticResource CardLabel}" Margin="0,0,0,10" />
                                        <TextBlock Text="Preview screenshot folder" Style="{StaticResource FieldLabel}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding ScreenshotFolder}" />
                                            <Button Grid.Column="2" Content="Browse…" Click="BrowseScreenshotFolder_OnClick" Style="{StaticResource TouchButton}" />
                                        </Grid>
                                        <TextBlock Text="Session data folder" Style="{StaticResource FieldLabel}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding SessionDataFolder}" />
                                            <Button Grid.Column="2" Content="Browse…" Click="BrowseSessionFolder_OnClick" Style="{StaticResource TouchButton}" />
                                        </Grid>
                                        <TextBlock Text="Full-resolution phone captures" Style="{StaticResource FieldLabel}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding PhoneCaptureFolder}" />
                                            <Button Grid.Column="2" Content="Browse…" Click="BrowsePhoneCaptureFolder_OnClick" Style="{StaticResource TouchButton}" />
                                        </Grid>
                                        <CheckBox Content="Automatically copy new Camera photos from the phone while scrcpy is connected"
                                                  IsChecked="{Binding AutomaticallyImportPhonePhotos}"
                                                  Margin="0,12,0,0"
                                                  MinHeight="32" />
                                        <CheckBox Content="Include framing overlays in preview screenshots"
                                                  IsChecked="{Binding IncludeOverlaysInScreenshot}"
                                                  MinHeight="32" />
                                        <CheckBox Content="Use live weather and automatic Windows location"
                                                  IsChecked="{Binding EnableNetworkConditions}"
                                                  MinHeight="32" />
                                        <TextBlock Text="On by default. Windows location is tried first. If unavailable, BigDataCloud may estimate the area from the public IP address. Coordinates are sent to Open-Meteo for weather, elevation, and time-zone data. A broad public sky-brightness tile is requested for light-pollution estimates. Screenshots, phone status, sessions, and logs are never uploaded."
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource PanelCard}">
                                    <StackPanel>
                                        <TextBlock Text="REFRESH &amp; DEFAULTS" Style="{StaticResource CardLabel}" Margin="0,0,0,10" />
                                        <UniformGrid Columns="2">
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Phone status (seconds)" Style="{StaticResource FieldLabel}" />
                                                <TextBox Text="{Binding StatusRefreshSeconds}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Weather (minutes)" Style="{StaticResource FieldLabel}" />
                                                <TextBox Text="{Binding WeatherRefreshMinutes}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Default exposure (seconds)" Style="{StaticResource FieldLabel}" />
                                                <TextBox Text="{Binding DefaultExposureSeconds}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Default frame count" Style="{StaticResource FieldLabel}" />
                                                <TextBox Text="{Binding DefaultFrameCount}" />
                                            </StackPanel>
                                        </UniformGrid>
                                        <TextBlock Text="Fallback location name" Style="{StaticResource FieldLabel}" />
                                        <TextBox Text="{Binding DefaultLocationName}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Border Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="NIGHT DISPLAY" Style="{StaticResource CardLabel}" Margin="0,0,0,10" />
                                        <TextBlock Text="Display mode" Style="{StaticResource FieldLabel}" />
                                        <ComboBox ItemsSource="{Binding NightModes}" SelectedItem="{Binding SelectedNightMode}" />
                                        <TextBlock Text="Also on the header button and F10. Full red removes blue and green from the interface and dims the preview without tinting it, so the frame you are judging stays true to colour."
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,10,0,0" />
                                        <TextBlock Text="Overlay opacity" Style="{StaticResource FieldLabel}" />
                                        <Slider Minimum="0.1" Maximum="1" Value="{Binding OverlayOpacity}" />
                                        <TextBlock Text="Overlay line thickness" Style="{StaticResource FieldLabel}" />
                                        <Slider Minimum="0.5" Maximum="6" Value="{Binding OverlayThickness}" />
                                        <TextBlock Text="Overlay color" Style="{StaticResource FieldLabel}" />
                                        <ComboBox ItemsSource="{Binding OverlayColorOptions}"
                                                  SelectedItem="{Binding OverlayColorName}" />
                                        <UniformGrid Columns="2">
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Rectangle width %" Style="{StaticResource FieldLabel}" />
                                                <TextBox Text="{Binding CustomRectangleWidthPercent}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Rectangle height %" Style="{StaticResource FieldLabel}" />
                                                <TextBox Text="{Binding CustomRectangleHeightPercent}" />
                                            </StackPanel>
                                        </UniformGrid>
                                        <TextBlock Text="Histogram update (milliseconds)" Style="{StaticResource FieldLabel}" />
                                        <TextBox Text="{Binding HistogramUpdateMilliseconds}" />
                                        <CheckBox Content="Show coordinate-mapping debug overlay"
                                                  IsChecked="{Binding DebugOverlay}"
                                                  Margin="0,12,0,0"
                                                  MinHeight="32" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="VIDEO &amp; WINDOW" Style="{StaticResource CardLabel}" Margin="0,0,0,10" />
                                        <TextBlock Text="AstroDesk display mode" Style="{StaticResource FieldLabel}" />
                                        <ComboBox ItemsSource="{Binding WindowModeOptions}"
                                                  SelectedItem="{Binding SelectedWindowMode, Mode=TwoWay}" />
                                        <TextBlock Text="Windowed keeps the normal title bar. Borderless window removes it without filling the screen. Windowed fullscreen stays maximized with Windows controls. Fullscreen uses the entire display without borders."
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource PanelCard}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="EXPERIMENTAL CAPTURE CONTROL" Style="{StaticResource CardLabel}" Margin="0,0,0,10" />
                                        <Border Background="{DynamicResource AccentMutedBrush}"
                                                BorderBrush="{DynamicResource WarningBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12">
                                            <TextBlock Text="Experimental: sends ADB taps to a configured Samsung Camera shutter coordinate. Verify coordinates with a harmless test; screen layout changes can make them wrong."
                                                       TextWrapping="Wrap" />
                                        </Border>
                                        <CheckBox Content="Enable experimental capture controls"
                                                  IsChecked="{Binding EnableExperimentalCaptureControls}"
                                                  Margin="0,12,0,0"
                                                  MinHeight="32" />
                                        <UniformGrid Columns="2">
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Shutter X" Style="{StaticResource FieldLabel}" />
                                                <TextBox Text="{Binding ExperimentalShutterX}" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Shutter Y" Style="{StaticResource FieldLabel}" />
                                                <TextBox Text="{Binding ExperimentalShutterY}" />
                                            </StackPanel>
                                        </UniformGrid>
                                        <CheckBox Content="Tap shutter at each exposure-timer frame"
                                                  IsChecked="{Binding ExperimentalTimerCapture}"
                                                  Margin="0,12,0,0"
                                                  MinHeight="32" />
                                        <Button Content="Send one test tap"
                                                Command="{Binding ExperimentalShutterTapCommand}"
                                                Style="{StaticResource TouchButton}"
                                                HorizontalAlignment="Left"
                                                Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource PanelCard}">
                                    <StackPanel>
                                        <TextBlock Text="KEYBOARD SHORTCUTS" Style="{StaticResource CardLabel}" Margin="0,0,0,10" />
                                        <TextBlock Text="F8  +1 frame" />
                                        <TextBlock Text="F9  Hide all overlays" Margin="0,5,0,0" />
                                        <TextBlock Text="F10  Cycle night mode" Margin="0,5,0,0" />
                                        <TextBlock Text="F11  Fullscreen preview" Margin="0,5,0,0" />
                                        <TextBlock Text="Ctrl+Shift+S  Preview screenshot" Margin="0,5,0,0" />
                                        <TextBlock Text="Shift+click / drag  Center or pan zoomed preview" Margin="0,5,0,0" />
                                        <TextBlock Text="Phone keyboard input is forwarded after clicking the embedded preview."
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>

                                <Button Content="Save settings"
                                        Command="{Binding SaveSettingsCommand}"
                                        Style="{StaticResource PrimaryTouchButton}"
                                        HorizontalAlignment="Right"
                                        Margin="0,12,0,0" />
                                <TextBlock Text="{Binding SettingsStatusText}"
                                           Style="{StaticResource MutedText}"
                                           HorizontalAlignment="Right"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>


            <!-- =========================== STACKING ==========================
                 Frames captured on a fixed tripod do not line up: the sky rotates
                 roughly 15 degrees an hour, so a star crosses hundreds of pixels
                 over a session. Averaging them unregistered yields trails, not a
                 cleaner image, which is why the heavy lifting is handed to Siril
                 for star-based registration before integration. -->
            <Grid Visibility="{Binding IsStacking, Converter={StaticResource BoolToVisibility}}"
                  Margin="18,16,18,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Stacking" Style="{StaticResource PageTitle}" />
                    <TextBlock Text="Collect a run of captures and integrate them into one low-noise frame."
                               Style="{StaticResource PageSubtitle}" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Control column -->
                    <Border Style="{StaticResource PanelCard}" Padding="16">
                        <!-- The control column grew past the panel height once auto
                             capture was added, so it scrolls rather than clipping
                             the Stack now button off the bottom. -->
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      PanningMode="VerticalFirst"
                                      PanningDeceleration="0.001"
                                      PanningRatio="1">
                        <StackPanel>
                            <TextBlock Text="STACK RUN" Style="{StaticResource RailHeader}" />

                            <TextBlock Text="Frames to collect" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,4" />
                            <TextBox Text="{Binding StackTargetFrameCount}"
                                     MinHeight="32"
                                     FontSize="12"
                                     Margin="0,0,0,4"
                                     ToolTip="Zero means keep collecting until you stop it" />
                            <TextBlock Text="More frames means less noise, but the sky rotates the whole time — registration handles that."
                                       Style="{StaticResource MutedText}"
                                       FontSize="10.5"
                                       Margin="0,0,0,12" />

                            <ToggleButton Content="Stack mode"
                                          IsChecked="{Binding IsStackArmed, Mode=OneWay}"
                                          Command="{Binding ToggleStackModeCommand}"
                                          Style="{StaticResource TouchToggleButton}"
                                          Margin="0,0,0,10"
                                          ToolTip="While armed, every photo taken on the phone is collected into this run" />

                            <!-- RangeBase.Value binds two-way by default, and StackProgress is a
                                 computed getter with no setter, so the mode must be stated
                                 explicitly or WPF throws while parsing this line. -->
                            <ProgressBar Value="{Binding StackProgress, Mode=OneWay}"
                                         Minimum="0"
                                         Maximum="1"
                                         Height="5"
                                         Margin="0,0,0,5" />
                            <TextBlock Text="{Binding StackProgressText}"
                                       Style="{StaticResource TelemetrySub}"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="{Binding StackStatusText}"
                                       Style="{StaticResource MutedText}"
                                       FontSize="11.5"
                                       Margin="0,0,0,12" />

                            <Border Style="{StaticResource Hairline}" />

                            <!-- Auto capture fires the phone's shutter on a cadence derived
                                 from the exposure, so a long run does not need a human
                                 pressing the button every 20 seconds. -->
                            <TextBlock Text="AUTO CAPTURE" Style="{StaticResource RailHeader}" />
                            <TextBlock Text="Camera app" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding CameraApps}"
                                      SelectedItem="{Binding SelectedCameraApp}"
                                      MinHeight="32"
                                      FontSize="12"
                                      Margin="0,0,0,3"
                                      ToolTip="Which app to shoot with. Captures are collected from the folder it writes to." />
                            <TextBlock Text="{Binding CameraAppFolderText}"
                                       Style="{StaticResource TelemetrySub}"
                                       FontSize="10"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="Write delay (s)" Style="{StaticResource RailLabel}" HorizontalAlignment="Left" Margin="0,0,0,4" />
                            <TextBox Text="{Binding AutoCaptureWriteDelaySeconds, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="32"
                                     FontSize="12"
                                     Margin="0,0,0,6"
                                     ToolTip="Time the phone needs to save the file after the exposure ends. RAW needs more than JPEG." />
                            <TextBlock Text="{Binding AutoCaptureIntervalText}"
                                       Style="{StaticResource TelemetrySub}"
                                       Margin="0,0,0,3" />
                            <TextBlock Text="{Binding AutoCaptureEstimatedRunText}"
                                       Style="{StaticResource TelemetrySub}"
                                       Margin="0,0,0,8" />
                            <ToggleButton Content="Auto capture"
                                          IsChecked="{Binding IsAutoCaptureRunning, Mode=OneWay}"
                                          Command="{Binding ToggleAutoCaptureCommand}"
                                          Style="{StaticResource TouchToggleButton}"
                                          Margin="0,0,0,6"
                                          ToolTip="Sends volume-up, then waits for each photo to arrive before the next. Samsung Camera must be open and its volume key set to take pictures." />
                            <TextBlock Text="{Binding AutoCaptureStatusText}"
                                       Style="{StaticResource MutedText}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding AutoCaptureTelemetryText}"
                                       Style="{StaticResource TelemetrySub}"
                                       FontSize="10"
                                       TextWrapping="Wrap"
                                       TextTrimming="None"
                                       Margin="0,0,0,3" />
                            <TextBlock Text="{Binding AutoCaptureUnaccountedText}"
                                       Style="{StaticResource TelemetrySub}"
                                       FontSize="10"
                                       Foreground="{DynamicResource WarningBrush}"
                                       TextWrapping="Wrap"
                                       TextTrimming="None"
                                       Margin="0,0,0,12" />

                            <Border Style="{StaticResource Hairline}" />

                            <TextBlock Text="INTEGRATE" Style="{StaticResource RailHeader}" />
                            <Button Content="Stack now"
                                    Command="{Binding RunStackCommand}"
                                    Style="{StaticResource PrimaryTouchButton}"
                                    IsEnabled="{Binding IsStackRunning, Converter={StaticResource BooleanNegation}}"
                                    Margin="0,0,0,8" />
                            <TextBlock Text="{Binding StackResultText}"
                                       Style="{StaticResource MutedText}"
                                       FontSize="11.5"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <Button Content="Open stack folder"
                                    Command="{Binding OpenStackFolderCommand}"
                                    Style="{StaticResource PanelButton}"
                                    Margin="0,0,0,8" />
                            <TextBlock Text="{Binding StackFolderText}"
                                       Style="{StaticResource TelemetrySub}"
                                       FontSize="10"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Frames + result column -->
                    <Border Grid.Column="2" Style="{StaticResource PanelCard}" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <!-- The finished stack, once one exists. Shown above the
                                     live view because it supersedes it. -->
                                <StackPanel Visibility="{Binding HasStackResult, Converter={StaticResource BoolToVisibility}}">
                                    <DockPanel LastChildFill="False" Margin="0,0,0,7">
                                        <TextBlock Text="STACKED RESULT" Style="{StaticResource RailHeader}" Margin="0" />
                                        <Button DockPanel.Dock="Right"
                                                Content="Open folder"
                                                Command="{Binding OpenStackFolderCommand}"
                                                Style="{StaticResource PanelButton}"
                                                MinHeight="24"
                                                Padding="8,2"
                                                FontSize="11" />
                                    </DockPanel>
                                    <Border Background="{DynamicResource PreviewBackgroundBrush}"
                                            BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            Height="300"
                                            Margin="0,0,0,4">
                                        <Image Source="{Binding StackResultImage}"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Border>
                                    <TextBlock Text="{Binding StackResultPath}"
                                               Style="{StaticResource TelemetrySub}"
                                               FontSize="10"
                                               TextWrapping="Wrap"
                                               TextTrimming="None"
                                               Margin="0,0,0,14" />
                                </StackPanel>

                                <DockPanel LastChildFill="False" Margin="0,0,0,7">
                                    <TextBlock Text="LIVE STACK" Style="{StaticResource RailHeader}" Margin="0" />
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding LivePreviewDriftText}"
                                               Style="{StaticResource TelemetrySub}"
                                               FontSize="10"
                                               Margin="10,0,0,0" />
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding LivePreviewFramesText}"
                                               Style="{StaticResource TelemetrySub}"
                                               FontSize="10" />
                                </DockPanel>
                                <Border Background="{DynamicResource PreviewBackgroundBrush}"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        Height="240"
                                        Margin="0,0,0,6"
                                        Visibility="{Binding HasLivePreview, Converter={StaticResource BoolToVisibility}}">
                                    <Image Source="{Binding LivePreviewImage}"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>
                                <Border Background="{DynamicResource PanelRaisedBrush}"
                                        CornerRadius="2"
                                        Height="240"
                                        Margin="0,0,0,6"
                                        Visibility="{Binding HasLivePreview, Converter={StaticResource InverseBoolToVisibility}}">
                                    <TextBlock Text="The running stack appears here once frames start arriving."
                                               Style="{StaticResource MutedText}"
                                               FontSize="11.5"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               MaxWidth="260"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <CheckBox Content="Update preview while capturing"
                                          IsChecked="{Binding IsLivePreviewEnabled}"
                                          FontSize="11.5"
                                          MinHeight="28"
                                          Margin="0,0,0,12" />

                                <TextBlock Text="COLLECTED FRAMES" Style="{StaticResource RailHeader}" />
                                <Border Background="{DynamicResource PanelRaisedBrush}"
                                        BorderBrush="{DynamicResource WarningBrush}"
                                        BorderThickness="1,0,0,0"
                                        Padding="12"
                                        Margin="0,0,0,12"
                                        Visibility="{Binding IsSirilAvailable, Converter={StaticResource InverseBoolToVisibility}}">
                                    <StackPanel>
                                        <TextBlock Text="Siril is not configured"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,5" />
                                        <TextBlock Text="Frames are still collected, but integration needs Siril. Install it, then set the siril-cli path in Settings under Android tools."
                                                   Style="{StaticResource MutedText}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Thumbnails rather than filenames: a glance tells you
                                 whether the frames are usable, which a list of
                                 timestamps never can. -->
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding StackFrameNames}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource PanelRaisedBrush}"
                                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="2"
                                                Width="132"
                                                Margin="0,0,8,8"
                                                Padding="3">
                                            <StackPanel>
                                                <Grid Height="86">
                                                    <Border Background="{DynamicResource PreviewBackgroundBrush}"
                                                            CornerRadius="1" />
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="UniformToFill"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                    <TextBlock Text="RAW"
                                                               Style="{StaticResource TelemetrySub}"
                                                               FontSize="10"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding HasThumbnail, Converter={StaticResource InverseBoolToVisibility}}" />
                                                </Grid>
                                                <TextBlock Text="{Binding FileName}"
                                                           Style="{StaticResource TelemetrySub}"
                                                           FontSize="9.5"
                                                           Margin="0,3,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding FileName}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Timer fullscreen overlay. -->
            <Grid Panel.ZIndex="100"
                  Visibility="{Binding IsTimerFullscreen, Converter={StaticResource BoolToVisibility}}"
                  Background="Black">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TimerPhaseText}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="24"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding TimerCountdownText}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontFamily="Consolas"
                               FontSize="148"
                               FontWeight="Bold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding TimerFrameText}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="29"
                               HorizontalAlignment="Center" />
                    <WrapPanel HorizontalAlignment="Center" Margin="0,28,0,0">
                        <Button Content="Pause" Command="{Binding PauseTimerCommand}" Style="{StaticResource TouchButton}" Margin="0,0,8,0" />
                        <Button Content="Resume" Command="{Binding ResumeTimerCommand}" Style="{StaticResource TouchButton}" Margin="0,0,8,0" />
                        <Button Content="Stop" Command="{Binding StopTimerCommand}" Style="{StaticResource DangerButton}" MinHeight="48" Padding="18,11" Margin="0,0,8,0" />
                        <Button Content="Exit fullscreen" Command="{Binding ToggleTimerFullscreenCommand}" Style="{StaticResource PrimaryTouchButton}" />
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <Border x:Name="StatusBar"
                Grid.Row="2"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource MutedText}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1"
                           Text="{Binding ConnectionStatus}"
                           Style="{StaticResource MutedText}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="560" />
            </Grid>
        </Border>
    </Grid>
</Window>
