<Window x:Class="AstroDesk.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:AstroDesk.App.Controls"
        mc:Ignorable="d"
        Title="AstroDesk"
        Width="1400"
        Height="900"
        MinWidth="1050"
        MinHeight="700"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_OnPreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <controls:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <controls:BooleanNegationConverter x:Key="BooleanNegation" />
    </Window.Resources>

    <Grid Background="{DynamicResource WorkspaceBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Border Width="38"
                            Height="38"
                            CornerRadius="12"
                            Background="{DynamicResource AccentBrush}"
                            Margin="0,0,12,0">
                        <TextBlock Text="✦"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource WindowBackgroundBrush}" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="AstroDesk"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Night shooting workspace"
                                   Style="{StaticResource MutedText}"
                                   FontSize="11" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Shoot"
                            Command="{Binding ShowDashboardCommand}"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDashboard}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PanelRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="History"
                            Command="{Binding ShowHistoryCommand}"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHistory}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PanelRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Settings"
                            Command="{Binding ShowSettingsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSettings}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PanelRaisedBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Style="{StaticResource StatusPill}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7"
                                     Height="7"
                                     Margin="0,0,7,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource SecondaryTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DeviceConnected}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding DeviceModel}"
                                       MaxWidth="100"
                                       ToolTip="{Binding DeviceModel}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatusPill}"
                            Margin="0,0,8,0">
                        <TextBlock Text="{Binding BatteryText, StringFormat=Battery · {0}}"
                                   MaxWidth="150"
                                   ToolTip="{Binding BatteryText}"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Border Style="{StaticResource StatusPill}">
                        <TextBlock Text="{Binding PhoneTemperatureText, StringFormat=Phone · {0}}"
                                   MaxWidth="145"
                                   ToolTip="{Binding PhoneTemperatureText}"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid Visibility="{Binding IsDashboard, Converter={StaticResource BoolToVisibility}}">
                <Grid Visibility="{Binding IsPreviewFullscreen, Converter={StaticResource InverseBoolToVisibility}}"
                      Margin="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="330" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelCard}" Padding="0">
                        <Grid>
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          PanningMode="VerticalFirst"
                                          PanningDeceleration="0.001"
                                          PanningRatio="1">
                                <StackPanel Margin="20">
                                    <DockPanel Margin="0,0,0,18">
                                        <StackPanel>
                                            <TextBlock Text="Night brief" Style="{StaticResource PageTitle}" FontSize="23" />
                                            <TextBlock Text="{Binding ConditionsUpdatedText}"
                                                       Style="{StaticResource PageSubtitle}" />
                                        </StackPanel>
                                        <Button DockPanel.Dock="Right"
                                                Content="↻"
                                                Command="{Binding RefreshConditionsCommand}"
                                                Style="{StaticResource CompactButton}"
                                                FontSize="17"
                                                MinWidth="36"
                                                ToolTip="Refresh conditions" />
                                    </DockPanel>

                                    <Border Style="{StaticResource SubtleCard}" Margin="0,0,0,14">
                                        <StackPanel>
                                            <DockPanel>
                                                <StackPanel>
                                                    <TextBlock Text="OBSERVING LOCATION"
                                                               Style="{StaticResource SectionTitle}" />
                                                    <TextBlock Text="{Binding LocationStatusText}"
                                                               FontWeight="SemiBold"
                                                               FontSize="15" />
                                                </StackPanel>
                                                <Border DockPanel.Dock="Right"
                                                        Width="9"
                                                        Height="9"
                                                        CornerRadius="5"
                                                        Background="{DynamicResource SuccessBrush}"
                                                        VerticalAlignment="Top"
                                                        Margin="8,5,0,0" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding LocationCoordinateText}"
                                                       Style="{StaticResource MutedText}"
                                                       Margin="0,5,0,0" />
                                            <TextBlock Text="{Binding TimeZoneText, StringFormat=Time zone · {0}}"
                                                       Style="{StaticResource MutedText}"
                                                       Margin="0,3,0,0" />
                                            <TextBlock Text="{Binding AltitudeText, StringFormat=Altitude · {0}}"
                                                       Style="{StaticResource MutedText}"
                                                       Margin="0,3,0,0" />
                                            <UniformGrid Columns="2" Margin="0,12,0,0">
                                                <Button Content="Locate me"
                                                        Command="{Binding LocateCurrentUserCommand}"
                                                        Style="{StaticResource AccentButton}"
                                                        Margin="0,0,5,0" />
                                                <Button Content="Windows settings"
                                                        Command="{Binding OpenLocationSettingsCommand}"
                                                        Style="{StaticResource ToolbarButton}"
                                                        Margin="5,0,0,0" />
                                            </UniformGrid>
                                            <Expander Header="Change observing location"
                                                      Margin="0,12,0,0">
                                                <StackPanel>
                                                    <ComboBox ItemsSource="{Binding Locations}"
                                                              SelectedItem="{Binding SelectedLocation}"
                                                              DisplayMemberPath="Name"
                                                              ToolTip="Select a saved or fallback observing area." />
                                                    <Grid Margin="0,9,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Text="{Binding LocationSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Search worldwide locations" />
                                                        <Button Grid.Column="2"
                                                                Content="Search"
                                                                Command="{Binding SearchLocationsCommand}"
                                                                Style="{StaticResource ToolbarButton}" />
                                                    </Grid>
                                                    <TextBlock Text="Manual coordinates"
                                                               Style="{StaticResource FieldLabel}" />
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Text="{Binding Latitude}" ToolTip="Latitude" />
                                                        <TextBox Grid.Column="2" Text="{Binding Longitude}" ToolTip="Longitude" />
                                                    </Grid>
                                                </StackPanel>
                                            </Expander>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource HeroCard}" Margin="0,0,0,18">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Text="TONIGHT"
                                                           Style="{StaticResource SectionTitle}"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Margin="0" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding ShootingScoreText}"
                                                           FontSize="21"
                                                           FontWeight="SemiBold"
                                                           Margin="12,0,0,0" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding ShootingRecommendationText}"
                                                       FontSize="21"
                                                       FontWeight="SemiBold"
                                                       Margin="0,12,0,0"
                                                       TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ShootQualityLevel}" Value="Excellent">
                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ShootQualityLevel}" Value="Fair">
                                                                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ShootQualityLevel}" Value="Poor">
                                                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                            </TextBlock>
                                            <Border Background="{DynamicResource WindowBackgroundBrush}"
                                                    CornerRadius="9"
                                                    Padding="11,8"
                                                    Margin="0,13,0,0">
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left"
                                                               Text="Best window"
                                                               Style="{StaticResource MutedText}" />
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="{Binding BestShootingWindowText}"
                                                               FontWeight="SemiBold" />
                                                </DockPanel>
                                            </Border>
                                            <TextBlock Text="{Binding ShootingAdviceText}"
                                                       Style="{StaticResource MutedText}"
                                                       Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="WEATHER NOW" Style="{StaticResource SectionTitle}" />
                                    <UniformGrid Columns="2" Margin="0,0,-8,8">
                                        <Border Style="{StaticResource MetricTile}">
                                            <StackPanel>
                                                <TextBlock Text="Temperature" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding TemperatureText}" Style="{StaticResource MetricValue}" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricTile}">
                                            <StackPanel>
                                                <TextBlock Text="Cloud cover" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding CloudCoverText}" Style="{StaticResource MetricValue}" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricTile}">
                                            <StackPanel>
                                                <TextBlock Text="Visibility" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding VisibilityText}" Style="{StaticResource MetricValue}" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricTile}">
                                            <StackPanel>
                                                <TextBlock Text="Rain chance" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding PrecipitationText}" Style="{StaticResource MetricValue}" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricTile}">
                                            <StackPanel>
                                                <TextBlock Text="Humidity" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding HumidityText}" Style="{StaticResource MetricValue}" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricTile}">
                                            <StackPanel>
                                                <TextBlock Text="Wind" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding WindText}" Style="{StaticResource MetricValue}" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                    <Border Style="{StaticResource SubtleCard}" Margin="0,0,0,18">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Dew point" Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding DewPointText}" FontWeight="SemiBold" Margin="0,3,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Text="Dew risk" Style="{StaticResource MutedText}" HorizontalAlignment="Right" />
                                                <TextBlock Text="{Binding DewRiskText}" FontWeight="SemiBold" Margin="0,3,0,0" HorizontalAlignment="Right" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="SKY &amp; DARKNESS" Style="{StaticResource SectionTitle}" />
                                    <Border Style="{StaticResource SubtleCard}" Margin="0,0,0,14">
                                        <StackPanel>
                                            <TextBlock Text="{Binding LightPollutionText}"
                                                       Style="{StaticResource MetricValue}" />
                                            <TextBlock Text="{Binding LightPollutionDetailText}"
                                                       Style="{StaticResource MutedText}"
                                                       Margin="0,5,0,0" />
                                            <Border Style="{StaticResource SeparatorLine}" />
                                            <DockPanel>
                                                <TextBlock Text="Dark-sky window" Style="{StaticResource MutedText}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding DarkSkyWindowText}"
                                                           FontWeight="SemiBold" />
                                            </DockPanel>
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="Sunset" Style="{StaticResource MutedText}" />
                                                <TextBlock Grid.Column="1" Text="{Binding SunsetText}" />
                                                <TextBlock Grid.Row="1" Text="Astronomical dusk" Style="{StaticResource MutedText}" Margin="0,7,0,0" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AstronomicalDuskText}" Margin="0,7,0,0" />
                                                <TextBlock Grid.Row="2" Text="Astronomical dawn" Style="{StaticResource MutedText}" Margin="0,7,0,0" />
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AstronomicalDawnText}" Margin="0,7,0,0" />
                                                <TextBlock Grid.Row="3" Text="Sunrise" Style="{StaticResource MutedText}" Margin="0,7,0,0" />
                                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SunriseText}" Margin="0,7,0,0" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SubtleCard}">
                                        <StackPanel>
                                            <DockPanel>
                                                <StackPanel>
                                                    <TextBlock Text="MOON" Style="{StaticResource SectionTitle}" />
                                                    <TextBlock Text="{Binding MoonPhaseText}" Style="{StaticResource MetricValue}" />
                                                </StackPanel>
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding MoonIlluminationText, StringFormat={}{0} lit}"
                                                           Style="{StaticResource MutedText}"
                                                           Margin="10,3,0,0" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding MoonPositionText}"
                                                       Margin="0,10,0,0"
                                                       FontWeight="SemiBold" />
                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Moonrise" Style="{StaticResource MutedText}" />
                                                    <TextBlock Text="{Binding MoonriseText}" Margin="0,3,0,0" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                    <TextBlock Text="Moonset" Style="{StaticResource MutedText}" HorizontalAlignment="Right" />
                                                    <TextBlock Text="{Binding MoonsetText}" Margin="0,3,0,0" HorizontalAlignment="Right" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      Visibility="Collapsed"
                                      PanningMode="VerticalFirst"
                                      PanningDeceleration="0.001"
                                      PanningRatio="1">
                            <StackPanel Margin="14">
                                <TextBlock Text="PHONE STATUS" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="{Binding ConnectionStatus}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                                <ComboBox ItemsSource="{Binding AvailableAdbDevices}"
                                          SelectedItem="{Binding SelectedAdbDevice}"
                                          DisplayMemberPath="DisplayName"
                                          ToolTip="Select an Android device when more than one is connected"
                                          Margin="0,0,0,8" />
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Android" Style="{StaticResource MutedText}" />
                                    <TextBlock Grid.Column="1" Text="{Binding AndroidVersionText}" />
                                    <TextBlock Grid.Row="1" Text="Storage" Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding StorageText}" Margin="0,6,0,0" TextAlignment="Right" />
                                    <TextBlock Grid.Row="2" Text="Display" Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ScreenResolutionText}" Margin="0,6,0,0" />
                                </Grid>
                                <TextBlock Text="{Binding OrientationText, StringFormat=Orientation: {0}}"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,7,0,0" />
                                <TextBlock Text="{Binding UsbStateText, StringFormat=USB: {0}}"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,3,0,0" />
                                <Border Style="{StaticResource SeparatorLine}" />
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="CONDITIONS" Style="{StaticResource SectionTitle}" />
                                    <Button DockPanel.Dock="Right"
                                            Content="↻"
                                            Command="{Binding RefreshConditionsCommand}"
                                            Style="{StaticResource ToolbarButton}"
                                            Padding="6,2"
                                            MinHeight="24"
                                            MinWidth="28" />
                                </DockPanel>

                                <TextBlock Text="YOUR LOCATION" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="{Binding LocationStatusText}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding LocationCoordinateText}"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,4,0,0" />
                                <TextBlock Text="{Binding TimeZoneText, StringFormat=Time zone: {0}}"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0" />
                                <TextBlock Text="{Binding AltitudeText, StringFormat=Altitude: {0}}"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,3,0,0" />
                                <UniformGrid Columns="2" Margin="0,8,0,0">
                                    <Button Content="Locate me"
                                            Command="{Binding LocateCurrentUserCommand}"
                                            Style="{StaticResource AccentButton}"
                                            Margin="0,0,4,0" />
                                    <Button Content="Location settings"
                                            Command="{Binding OpenLocationSettingsCommand}"
                                            Style="{StaticResource ToolbarButton}"
                                            Margin="4,0,0,0" />
                                </UniformGrid>

                                <TextBlock Text="Fallback location"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="0,12,0,0" />
                                <ComboBox ItemsSource="{Binding Locations}"
                                          SelectedItem="{Binding SelectedLocation}"
                                          DisplayMemberPath="Name"
                                          ToolTip="Used when Windows location is unavailable or when you select a different observing area." />
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding LocationSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Search worldwide locations" />
                                    <Button Grid.Column="2"
                                            Content="Search"
                                            Command="{Binding SearchLocationsCommand}"
                                            Style="{StaticResource ToolbarButton}" />
                                </Grid>
                                <TextBlock Text="Manual coordinates"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="0,7,0,0" />
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding Latitude}" ToolTip="Manual latitude" />
                                    <TextBox Grid.Column="2" Text="{Binding Longitude}" ToolTip="Manual longitude" />
                                </Grid>

                                <Border Style="{StaticResource SeparatorLine}" />
                                <TextBlock Text="TONIGHT" Style="{StaticResource SectionTitle}" />
                                <Border Background="{DynamicResource AccentMutedBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ShootingRecommendationText}"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock"
                                                       BasedOn="{StaticResource MetricValue}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShootQualityLevel}" Value="Excellent">
                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ShootQualityLevel}" Value="Good">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ShootQualityLevel}" Value="Fair">
                                                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ShootQualityLevel}" Value="Poor">
                                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ShootQualityLevel}" Value="Unavailable">
                                                            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding ShootingScoreText, StringFormat=Score: {0}}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding BestShootingWindowText, StringFormat=Best: {0}}"
                                                       TextAlignment="Right"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                        <TextBlock Text="{Binding ShootingAdviceText}"
                                                   Style="{StaticResource MutedText}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,7,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SeparatorLine}" />
                                <TextBlock Text="WEATHER" Style="{StaticResource SectionTitle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
